# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
.venv/
venv/
.python-version

# uv
uv.lock

# Tooling caches
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Claude Code per-project state (sessions, locks, worktrees)
.claude/

# Prehnite runtime output (keep the directory itself, ignore its contents)
/trajectories/*
!/trajectories/.gitkeep

# Per-task agent subprocess logs from `prehnite batch`
/batch-logs/

# MCP server session descriptors (resumable session state)
/sessions/

# Content-addressed overflow for capped trajectory streams (stdout/stderr
# that exceeded the per-event byte budget). Reviewable on disk but not
# committed.
/overflow/
